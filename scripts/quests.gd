static func xp_for_gnome(cfg: Dictionary) -> int:
	return clampi(int(cfg.hp * 0.45), 8, 200)


static func xp_to_next(level: int) -> int:
	return 90 + 60 * (level - 1)


## Характеристики героя: str/vit/agi/luck — очки, вложенные игроком,
## плюс бонусы древа навыков (Skills), растущего из этих же характеристик.
static func max_hp_for(p: Dictionary) -> int:
	var base: int = 100 + 4 * (int(p.get("level", 1)) - 1) + 12 * int(p.get("vit", 0))
	return roundi(base * Skills.max_hp_mult(p))


static func dmg_mult_for(p: Dictionary) -> float:
	return (1.0 + 0.06 * p.get("str", 0)) * Skills.dmg_mult(p)


static func speed_mult_for(p: Dictionary) -> float:
	return (1.0 + 0.04 * p.get("agi", 0)) * Skills.speed_mult(p)


static func crit_chance_for(p: Dictionary) -> float:
	return 0.12 + 0.02 * p.get("luck", 0)


static func crit_dmg_mult_for(p: Dictionary) -> float:
	return Skills.crit_dmg_mult(p)


## Уровень врагов: растёт по главам сюжета и волнам выживания.
static func enemy_hp_mult(lvl: int) -> float:
	return 1.0 + 0.18 * (lvl - 1)


static func enemy_dmg_mult(lvl: int) -> float:
	return 1.0 + 0.12 * (lvl - 1)


static func enemy_xp_mult(lvl: int) -> float:
	return 1.0 + 0.15 * (lvl - 1)
