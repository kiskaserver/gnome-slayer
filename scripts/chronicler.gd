class_name Chronicler
extends RefCounted
## Летописец (5.0): саркастичный голос игры. Ведёт хронику похода в ленте
## событий — короткие реплики на события, никогда не блокирует игру.
## Чисто клиентский: каждая машина видит одни и те же события и получает
## одни и те же строки, сети не нужно.

var game # Game-владелец (hud, состояние)

var _said: Dictionary = {}  # одноразовые реплики этого матча

# реплики старта глав — по школе главы
const CH_START := [
	"Хроника, глава первая: герой прибыл на поляну. Заборы уже сломаны — нигилисты постарались. Говорят, ничто не имеет смысла. Проверим на них.",
	"Хроника, глава вторая: осень, дым и запах жареных грибов. Гедонисты пируют. Герой приглашён — в качестве блюда, судя по табору.",
	"Хроника, глава третья: зима. Стоики отобрали у деревни дрова — «страдание закаляет». Герой намерен закалить их обратно.",
	"Хроника, глава четвёртая: ночь и погост. Некророманты уверяют, что смерть — просто смена жанра. Герой предпочитает свой жанр: боевик.",
	"Хроника, глава пятая: рой у ворот. Личность — иллюзия, говорят они хором. Герой — очень настойчивая иллюзия с секирой.",
	"Хроника, глава последняя: логово Дунгрима. Король подарил миру свободу от смысла. Мир просил не дарить.",
]

const DOWNED := [
	"Хроника: герой прилёг изучить землю вблизи. Наука требует жертв.",
	"Хроника: герой временно согласился с нигилистами. Подъём, рыцарь.",
]


func _init(game_) -> void:
	game = game_


## Одноразовая реплика (ключ = и текст, и метка «уже сказано»).
func say_once(text: String) -> void:
	if _said.has(text):
		return
	_said[text] = true
	say(text)


func say(text: String) -> void:
	game.hud.add_chat(tr("Летописец"), tr(text), true)


func chapter_start() -> void:
	# мир пересоздаётся и при возврате из подземелья — главу открываем один раз
	if Net.chronicled_chapter == Net.campaign_chapter:
		return
	Net.chronicled_chapter = Net.campaign_chapter
	var i: int = clampi(Net.campaign_chapter - 1, 0, CH_START.size() - 1)
	say_once(CH_START[i])
	# приветствие по происхождению — только в первой главе
	if Net.campaign_chapter == 1:
		var o: Dictionary = Quests.ORIGINS.get(Save.hero_origin, {})
		if not o.is_empty():
			say_once(o.line)


func on_downed_local() -> void:
	say(DOWNED[randi() % DOWNED.size()])


func on_first_chest() -> void:
	say_once("Хроника: герой нашёл ящик. Смысла внутри не было — только зелья. Тоже неплохо.")


func on_elite() -> void:
	say_once("Хроника: золотой гном. Единственный, кто нашёл в осколке хоть какую-то ценность.")


func on_boss_dead() -> void:
	say(tr("Хроника: аргумент опровергнут. Осколок молчит — впервые за долгое время."))


func on_doctrine(steel: bool) -> void:
	if steel:
		say("Хроника: герой ответил Сталью. Коротко, убедительно, без сносок.")
	else:
		say("Хроника: герой ответил Словом. Хранитель задумался. Думающий хранитель — уязвимый хранитель.")


## Вердикт похода — в финале кампании (вызывает сервер через sys-строку,
## здесь только локальная версия для одиночки).
static func verdict_key(steel: int, word: int) -> String:
	if steel > word:
		return "Вердикт Летописца: этот поход прошёл Мечом. Просто, честно, шумно."
	if word > steel:
		return "Вердикт Летописца: этот поход прошёл Мыслью. Хранители до сих пор сомневаются."
	return "Вердикт Летописца: Меч и Мысль шли поровну. Редкий случай: герой оказался сложнее своих врагов."
