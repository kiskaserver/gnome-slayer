; Engine configuration file.
config_version=5

[application]

config/name="Гномобой"
config/version="5.0.0"
config/icon="res://icon.png"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

Settings="*res://scripts/settings.gd"
Net="*res://scripts/net.gd"
Sfx="*res://scripts/sfx.gd"
Voice="*res://scripts/voice.gd"
Music="*res://scripts/music.gd"
Save="*res://scripts/savegame.gd"
Discord="*res://scripts/discord.gd"
Achievements="*res://scripts/achievements.gd"

[internationalization]

locale/translations=PackedStringArray("res://locale/translations.ru.translation", "res://locale/translations.uk.translation", "res://locale/translations.en.translation")
locale/fallback="ru"

[audio]

driver/enable_input=true

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[rendering]

anti_aliasing/quality/msaa_3d=2
